<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.slimene.memorycardgame.GameController">

    <top>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label fx:id="titleLabel" text="Memory Card Game"/>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Difficulty:"/>
                <ComboBox fx:id="difficultyBox"/>
            </HBox>

            <Label fx:id="movesLabel" text="Moves: 0"/>
            <Label fx:id="timeLabel" text="Time: 0 s"/>
            <Label fx:id="bestMovesLabel" text="Best Moves: -"/>
            <Label fx:id="bestTimeLabel" text="Best Time: -"/>
            <Label fx:id="statusLabel" text="Find all matching pairs!"/>

            <Button fx:id="restartButton" text="Restart"/>
        </VBox>
    </top>

    <center>
        <GridPane fx:id="grid" alignment="CENTER"/>
    </center>

</BorderPane>